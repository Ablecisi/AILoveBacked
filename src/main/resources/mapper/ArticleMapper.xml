<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
  创建时间：2025/8/22 22:58
  作者：Ablecisi
-->
<mapper namespace="com.ablecisi.ailovebacked.mapper.ArticleMapper">

    <resultMap id="ArticleResultMap" type="com.ablecisi.ailovebacked.pojo.entity.Article">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="content" property="content"/>
        <result column="cover_image_url" property="coverImageUrl"/>
        <result column="user_id" property="userId"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="tags" property="tags"
                typeHandler="com.ablecisi.ailovebacked.handler.JsonStringListTypeHandler"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="ArticleResultMap">
        SELECT *
        FROM article
        WHERE id = #{articleId}
    </select>
    <select id="selectRelatedArticlesByTags" resultMap="ArticleResultMap">
        SELECT *
        FROM article
        WHERE id != #{articleId}
        AND JSON_OVERLAPS(tags, JSON_ARRAY(
        <foreach collection="tags" item="tag" separator=','>
            #{tag}
        </foreach>
        ))
        ORDER BY update_time DESC
        LIMIT 10
    </select>
    <select id="selectHotArticles" resultMap="ArticleResultMap">
        SELECT *
        FROM article
        ORDER BY view_count AND comment_count * 3 AND like_count * 5 DESC
        LIMIT 10
    </select>

    <select id="countPageForAdmin" resultType="long">
        SELECT COUNT(*) FROM article
        <where>
            <if test="keyword != null and keyword != ''">
                AND title LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
    </select>

    <resultMap id="AdminArticleListMap" type="com.ablecisi.ailovebacked.pojo.vo.admin.AdminArticleListVO">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="content" property="content"/>
        <result column="cover_image_url" property="coverImageUrl"/>
        <result column="user_id" property="userId"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="tags" property="tags"
                typeHandler="com.ablecisi.ailovebacked.handler.JsonStringListTypeHandler"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="pageForAdmin" resultMap="AdminArticleListMap">
        SELECT id,
        title,
        description,
        content,
        cover_image_url,
        user_id,
        view_count,
        like_count,
        comment_count,
        tags,
        create_time,
        update_time
        FROM article
        <where>
            <if test="keyword != null and keyword != ''">
                AND title LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY id DESC
        LIMIT #{offset}, #{size}
    </select>

    <insert id="insert" parameterType="com.ablecisi.ailovebacked.pojo.entity.Article" useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO article (title, description, content, cover_image_url, user_id, view_count, like_count,
                             comment_count, tags, create_time, update_time)
        VALUES (#{title}, #{description}, #{content}, #{coverImageUrl}, #{userId},
                #{viewCount}, #{likeCount}, #{commentCount},
                #{tags, typeHandler=com.ablecisi.ailovebacked.handler.JsonStringListTypeHandler},
                NOW(), NOW())
    </insert>

    <update id="updateRow" parameterType="com.ablecisi.ailovebacked.pojo.entity.Article">
        UPDATE article
        SET title           = #{title},
            description     = #{description},
            content         = #{content},
            cover_image_url = #{coverImageUrl},
            user_id         = #{userId},
            view_count      = #{viewCount},
            like_count      = #{likeCount},
            comment_count   = #{commentCount},
            tags            = #{tags, typeHandler=com.ablecisi.ailovebacked.handler.JsonStringListTypeHandler},
            update_time     = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE
        FROM article
        WHERE id = #{id}
    </delete>

    <update id="adjustLikeCount">
        UPDATE article
        SET like_count  = GREATEST(0, IFNULL(like_count, 0) + #{delta}),
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <update id="incrementViewCount">
        UPDATE article
        SET view_count  = IFNULL(view_count, 0) + 1,
            update_time = NOW()
        WHERE id = #{id}
    </update>
</mapper>
